class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int largest = arr[0];
        int second = Integer.MIN_VALUE;
        for(int i=1;i<arr.length;i++){
            if(arr[i]>largest){
                second = largest;
                largest = arr[i];
            }
            else if (arr[i] > second && arr[i] != largest) {
        second = arr[i];
    }
        }
        if(second==Integer.MIN_VALUE) return -1;
        return second;
    }
}
